PORT=3000
SEARCH_INDEX_URL=https://search.appnativeitalia.com/indexes/testi_ecclesiali/search
DEFAULT_SEARCH_INDEX=testi_ecclesiali
SEARCH_API_KEY=put-your-api-key-here
SEARCH_API_KEY_BOLLETTINO=put-your-bollettino-api-key-here
OLLAMA_BASE_URL=http://127.0.0.1:11434
OLLAMA_NON_STREAM_TIMEOUT_MS=90000
DEFAULT_SEARCH_QUERY="papa leone"
DEFAULT_LIMIT=5
DEFAULT_MODEL=gemma:7b
DEFAULT_AGENT_MODEL=gemma:7b
MAX_TEXT_EXCERPT_CHARS=1800
MAX_CONTEXT_DOCS=3
SEARCH_CANDIDATE_MULTIPLIER=3

